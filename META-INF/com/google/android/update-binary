#!/sbin/sh
# TWRP A/B & Vendor Boot Installer Backend
# Modified for Vendor Boot support with smart hexpatch and repack bypass
# By osm0sis, Dees_Troy, isus203 and topjohnwu

OUTFD=/proc/self/fd/$2;
ZIPFILE="$3";

ui_print() {
  if $BOOTMODE; then
    echo "$1";
  else
    echo -e "ui_print $1\nui_print" >> $OUTFD;
  fi;
}
abort() { ui_print " "; ui_print "$1"; exit 1; }

# detect Magisk app/booted flashing
BOOTMODE=false;
ps | grep zygote | grep -v grep >/dev/null && BOOTMODE=true;
$BOOTMODE || ps -A 2>/dev/null | grep zygote | grep -v grep >/dev/null && BOOTMODE=true;

ui_print "########################################";
ui_print "#    TWRP installer for A/B devices    #";
ui_print "########################################";
ui_print " ";

# /dev/tmp is safe for both booted and recovery installs
tmp=/dev/tmp/twrp-install;
partdir=/dev/block/bootdevice/by-name

if [ ! -d $partdir ]; then
  partdir=/dev/block/by-name
fi

if [ ! -d $partdir ]; then
  abort "Failed unable to find the partition!";
fi

# Auto-detect target partition: vendor_boot -> recovery -> boot
if [ -e ${partdir}/vendor_boot_a ] || [ -e ${partdir}/vendor_boot_b ]; then
  target=${partdir}/vendor_boot;
else
  if [ -e ${partdir}/recovery ]; then
    target=${partdir}/recovery;
  else
    target=${partdir}/boot;
  fi;
fi;
name=$(basename $target);

ui_print "Unpacking the installer...";
rm -rf $tmp;
mkdir -p $tmp;
unzip -o "$ZIPFILE" -d $tmp || abort "Failed to extract zip!";

cd $tmp;
recoverycpio=`(ls ramdisk-twrp.cpio || ls ramdisk-recovery.cpio) 2>/dev/null`;
recoveryimg=`(ls twrp*.img || ls TWRAP*.img || ls recovery.img || ls vendor_boot*.img) 2>/dev/null`;

# Verification: For vendor_boot devices, a pre-built .img file is required.
if [ "$name" = "vendor_boot" ] && [ -z "$recoveryimg" ]; then
  abort "Error: For vendor_boot devices you must provide a ready TWRP image (recovery.img / vendor_boot.img) inside the zip! CPIO patching is ignored due to multiple ramdisks.";
fi;

[ "$recoverycpio" ] || [ "$recoveryimg" ] || abort "No TWRP ramdisk/image found in zip!";

chmod 755 magiskboot-arm*;
if ./magiskboot-arm64 cleanup 2>/dev/null; then
  mv -f magiskboot-arm64 magiskboot;
else
  mv -f magiskboot-arm magiskboot;
fi;
rm -f magiskboot-arm*;
tool=./magiskboot;

ui_print " ";
for slot in _a _b; do
  local_img="${name}.img"
  new_img="new-${name}.img"

  # We patch the image on the fly only if there is a cpio ramdisk AND it is NOT the vendor_boot partition
  if [ "$recoverycpio" ] && [ "$name" != "vendor_boot" ]; then
    ui_print "Running image patcher on $name$slot...";
    dd bs=1048576 if=$target$slot of=$local_img || abort "Failed to dump image!";
    $tool unpack -h $local_img || abort "Failed to unpack image!";

    # Patch the kernel (only on older devices where $name is boot or recovery)
    $tool hexpatch kernel 77616E745F696E697472616D6673 736B69705F696E697472616D6673;
    $tool hexpatch kernel 747269705F696E697472616D6673 736B69705F696E697472616D6673;

    # boot.img header cmdline remove skip_override (flar2 patch)
    sed -i "s|$(grep '^cmdline=' header | cut -d= -f2-)|$(grep '^cmdline=' header | cut -d= -f2- | sed -e 's/skip_override//' -e 's/  */ /g' -e 's/[ \t]*$//')|" header;

    cp -f $recoverycpio ramdisk.cpio;
    $tool repack $local_img || abort "Failed to repack image!";
    mv -f $local_img $new_img;
    $tool cleanup;
  else
    # The script always comes here for vendor_boot, or if a ready-made .img file was fed to old partitions
    ui_print "Bypassing repacker. Preparing clean flash for $name$slot...";
    cp -f $recoveryimg $new_img;
  fi;

  ui_print "Flashing $new_img to $name$slot...";
  blockdev --setrw $target$slot;
  cat $new_img /dev/zero > $target$slot 2>/dev/null || true;
  rm -f $new_img;
done;

if [ "$recoverycpio" ] && [ "$name" != "vendor_boot" ]; then
  ui_print " ";
  ui_print "Image patching complete!";
fi;

cd /;
rm -rf /dev/tmp;

ui_print " ";
ui_print "Done installing TWRP!";
if [ "$name" != "recovery" ]; then
  ui_print " ";
  ui_print "*** NOTE: You are now unrooted! ***";
fi;
